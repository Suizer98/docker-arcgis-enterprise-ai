ESRI_VERSION=11.4

USERNAME=arcgis
PASSWORD=samplepassword

# Fully qualified domain name for your servers (Esri requires FQDN in Portal URL / Web Adaptor).
# Use a multi-part name (at least one dot), e.g. PORTAL.LOCAL — not a single label like "portal".
# Add the same name to your OS hosts file pointing at 127.0.0.1 if you open Portal in a browser.
PORTAL=PORTAL.LOCAL
GISSERVER=SERVER.LOCAL
DATASTORE=DATASTORE.LOCAL

# postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=samplepassword
#POSTGRES_HOST_AUTH_METHOD=
#PGDATA=

# pgadmin4
# The username has to be in the form of an email address.
PGADMIN_USER=sz.tey@esrisingapore.com.sg
PGADMIN_PASSWORD=samplepassword

# Groq AI Agent
# Get your API key from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
DEBUG=false
MCP_USERNAME=arcgis
MCP_PASSWORD=samplepassword

# Web Adaptor (optional)
WA_NAME=localhost
# In the Web Adaptor UI, "Portal Name" is ONLY the hostname (FQDN), e.g. PORTAL.LOCAL — not a URL.
# Do not enter https://, port, /arcgis, or 127.0.0.1 (inside the container 127.0.0.1 is not Portal).
# Omit PORTAL_NAME below to use the same value as PORTAL.
# PORTAL_NAME=PORTAL.LOCAL
AGS_USER=arcgis
AGS_PASSWORD=samplepassword
AGS_DOMAIN=
WA_HTTP_PORT=9080
WA_HTTPS_PORT=9443
# Portal Web Adaptor: use https://localhost/arcgis/webadaptor/ (compose maps host 443→container 443).
# If Docker cannot bind 443 (IIS, etc.), remove the "443:443" line in compose.yaml and use :9443 only.

# Keycloak OIDC (optional) — docker compose up keycloak
# Generate TLS cert first: sh nginx/generate-ssl.sh
# If certs already exist, delete nginx/ssl/server.* and rerun to add DNS:keycloak SAN.
KEYCLOAK_HOST=127.0.0.1
KEYCLOAK_PORT=8180
KEYCLOAK_HOSTNAME=localhost
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin
#
# Portal OIDC uses TWO hostnames (browser vs container):
#   Browser (issuer, authorize): https://localhost:8180/realms/arcgis/...
#   Portal server (token, userinfo, jwks): https://keycloak:8443/realms/arcgis/...
# Import discovery from https://localhost:8180/realms/arcgis/.well-known/openid-configuration
# then edit Token, Userinfo, and JWKS URLs to use keycloak:8443 instead of localhost:8180.
# Client ID: arcgis-portal, Secret: arcgis-portal-secret
# Claims: User ID=preferred_username, Email=email, Full name=name, Scope=openid profile email
# Advanced: enable "Send access token in header" if user profile errors persist
# Do NOT use host.docker.internal in the browser — it often times out on WSL/Windows.
