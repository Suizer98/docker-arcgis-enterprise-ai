{
  "realm": "arcgis",
  "enabled": true,
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": false,
  "clients": [
    {
      "clientId": "arcgis-portal",
      "name": "ArcGIS Portal",
      "enabled": true,
      "clientAuthenticatorType": "client-secret",
      "secret": "arcgis-portal-secret",
      "redirectUris": [
        "https://localhost/arcgis/sharing/rest/oauth2/signin",
        "https://localhost/arcgis/sharing/rest/oauth2/oidc/*",
        "https://127.0.0.1/arcgis/sharing/rest/oauth2/signin",
        "https://127.0.0.1/arcgis/sharing/rest/oauth2/oidc/*",
        "https://localhost:9443/arcgis/sharing/rest/oauth2/signin",
        "https://localhost:9443/arcgis/sharing/rest/oauth2/oidc/*",
        "https://portal.local:7443/arcgis/sharing/rest/oauth2/signin",
        "https://portal.local:7443/arcgis/sharing/rest/oauth2/oidc/*"
      ],
      "webOrigins": [
        "https://localhost",
        "https://127.0.0.1",
        "https://portal.local:7443"
      ],
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "publicClient": false,
      "protocol": "openid-connect",
      "fullScopeAllowed": true,
      "defaultClientScopes": [
        "web-origins",
        "acr",
        "profile",
        "roles",
        "basic",
        "email"
      ],
      "optionalClientScopes": [
        "address",
        "phone",
        "offline_access",
        "microprofile-jwt"
      ],
      "protocolMappers": [
        {
          "name": "preferred_username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ],
      "attributes": {
        "post.logout.redirect.uris": "+"
      }
    }
  ],
  "users": [
    {
      "username": "portaluser",
      "enabled": true,
      "emailVerified": true,
      "email": "portaluser@example.com",
      "firstName": "Portal",
      "lastName": "User",
      "credentials": [
        {
          "type": "password",
          "value": "portaluser",
          "temporary": false
        }
      ]
    }
  ]
}
